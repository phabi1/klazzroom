{
  "name": "client-portal-web",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "klazzroom",
  "sourceRoot": "apps/client/portal/web/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:browser",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/client/portal/web",
        "index": "apps/client/portal/web/src/index.html",
        "main": "apps/client/portal/web/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/client/portal/web/tsconfig.app.json",
        "assets": [
          "apps/client/portal/web/src/favicon.ico",
          "apps/client/portal/web/src/assets"
        ],
        "styles": [
          "@angular/material/prebuilt-themes/indigo-pink.css",
          "apps/client/portal/web/src/styles.css"
        ],
        "scripts": []
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "2kb",
              "maximumError": "4kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "buildOptimizer": false,
          "optimization": false,
          "vendorChunk": true,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "configurations": {
        "production": {
          "browserTarget": "client-portal-web:build:production"
        },
        "development": {
          "browserTarget": "client-portal-web:build:development",
          "host": "0.0.0.0",
          "allowedHosts": ["portal-klazzzroom.docker.localhost"]
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "browserTarget": "client-portal-web:build"
      }
    },
    "lint": {
      "executor": "@nx/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": [
          "apps/client/portal/web/**/*.ts",
          "apps/client/portal/web/**/*.html"
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/client/portal/web/jest.config.ts",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true
        }
      }
    },
    "serve-static": {
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "client-portal-web:build"
      }
    },
    "docker-build": {
      "dependsOn": ["build"],
      "command": "docker build -f apps/client/portal/web/Dockerfile . -t r88x66nm.c1.gra9.container-registry.ovh.net/klazzroom/client-portal-web && docker push r88x66nm.c1.gra9.container-registry.ovh.net/klazzroom/client-portal-web"
    },
    "container": {
      "executor": "@nx-tools/nx-container:build",
      "dependsOn": ["build"],
      "options": {
        "engine": "docker",
        "metadata": {
          "images": ["r88x66nm.c1.gra9.container-registry.ovh.net/klazzroom/client-portal-web"],
          "load": true,
          "tags": [
            "type=schedule",
            "type=ref,event=branch",
            "type=ref,event=tag",
            "type=ref,event=pr",
            "type=sha,prefix=sha-"
          ]
        }
      }
    }
  }
}
